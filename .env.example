GROQ_API_KEY=gsk_...
# Optional override — defaults to openai/gpt-oss-120b if unset. Check
# https://console.groq.com/docs/models for what's current before the demo.
GROQ_MODEL=openai/gpt-oss-120b
PORT=3001
# Set to "production" on your hosted deployment. Among other things, this
# guarantees the dev-payment-proxy route (below) can never be mounted there
# even if ENABLE_DEV_PAYMENT_PROXY is accidentally left set to true.
NODE_ENV=development

# --- x402 payments (optional — leave ENABLE_X402_PAYMENTS unset/false to skip) ---
# Apply for an API key at https://web3.okx.com/zh-hans/onchainos/dev-portal
ENABLE_X402_PAYMENTS=false
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
PAY_TO_ADDRESS=
# eip155:1952 = X Layer Testnet (default, safe to test with fake funds)
# eip155:196  = X Layer Mainnet (real funds — switch only once validated)
X402_NETWORK=eip155:1952
X402_PRICE_RISK_CONSENSUS=$0.05
X402_PRICE_COVERAGE_MATCH=$0.01

# --- Dev-only: lets YOUR OWN dashboard auto-pay its own paywalled endpoints ---
# TESTNET KEY ONLY. Never a mainnet/real-funds key. Never commit this.
# Get free testnet funds: https://www.okx.com/xlayer/faucet/xlayerfaucet
# Leave blank if ENABLE_X402_PAYMENTS is false — not needed.
DEV_BUYER_PRIVATE_KEY=

# Set to "true" for LOCAL dev only, so your dashboard can use the dev-buyer
# proxy above. NEVER set this to true on a hosted/production deployment —
# that proxy holds a private key and the route must not be publicly
# reachable. The server also refuses to mount it if NODE_ENV=production,
# regardless of this flag, as a second layer of protection.
ENABLE_DEV_PAYMENT_PROXY=false

# Optional: DeFiLlama has no key requirement, left here in case that changes
DEFILLAMA_BASE_URL=https://api.llama.fi

# --- Contract-address lookups (for requests with no protocolSlug) ---
# Free tier at https://etherscan.io/apis — covers Ethereum + Arbitrum via one key.
ETHERSCAN_API_KEY=
# X Layer lookups reuse OKX_API_KEY/OKX_SECRET_KEY/OKX_PASSPHRASE above by default
# (OKLink is an OKX product). Only set these if that doesn't work and you need
# a separate key from oklink.com specifically:
OKLINK_API_KEY=
OKLINK_SECRET_KEY=
OKLINK_PASSPHRASE=
